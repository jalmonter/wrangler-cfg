{
  "name": "wrangler-cfg",
  "version": "1.0.0",
  "description": "Migrate your Wrangler configuration from TOML to JSONC syntax.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "prepublish": "npm run build",
    "start": "npm run build && node dist/index.js"
  },
  "keywords": [
    "wrangler",
    "cloudflare",
    "workers",
