  "author": "Johnny Almonte",
  "license": "MIT",
  "bin": {
    "wrangler-cfg": "./dist/index.js"
  },
  "dependencies": {
    "wrangler": "^3.114.0",
    "yargs": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/yargs": "^17.0.33",
    "typescript": "^5.0.0"
  }
